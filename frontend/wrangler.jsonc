{
    "name": "oynx-interactive", // Ensure this matches your project name in Cloudflare
    "compatibility_date": "2026-07-16",
    "compatibility_flags": [
        "nodejs_compat"
    ],
    "main": ".open-next/worker.js",
    "assets": {
        "directory": ".open-next/assets",
        "binding": "ASSETS"
    },
    "services": [
        {
            "binding": "WORKER_SELF_REFERENCE",
            "service": "oynx-interactive" // Ensure this matches your project name
        }
    ]
}